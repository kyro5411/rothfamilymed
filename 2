<div class="photo-strip">
  <div class="photo-strip-item"><img src="https://images.unsplash.com/photo-1571019613454-1cb2f99b2d8b?auto=format&fit=crop&w=500&q=80" alt="Family" loading="lazy"/></div>
  <div class="photo-strip-item"><img src="https://images.unsplash.com/photo-1469474968028-56623f02e42e?auto=format&fit=crop&w=500&q=80" alt="Mountains" loading="lazy"/></div>
  <div class="photo-strip-item"><img src="https://images.unsplash.com/photo-1559839734-2b71ea197ec2?auto=format&fit=crop&w=500&q=80" alt="Care" loading="lazy"/></div>
  <div class="photo-strip-item"><img src="https://images.unsplash.com/photo-1551632811-561732d1e306?auto=format&fit=crop&w=500&q=80" alt="Hiking" loading="lazy"/></div>
  <div class="photo-strip-item"><img src="https://images.unsplash.com/photo-1506905925346-21bda4d32df4?auto=format&fit=crop&w=500&q=80" alt="Idaho" loading="lazy"/></div>
